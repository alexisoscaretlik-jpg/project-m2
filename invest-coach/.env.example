# Copy to .env and fill in values. Never commit .env.

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- AI providers ---
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# --- SEC EDGAR ---
# SEC requires a real User-Agent. Format: "Name email@domain.com"
# Using a generic bot UA returns 403.
SEC_USER_AGENT=Invest Coach contact@yourdomain.com

# --- Next.js public (browser-exposed; DO NOT use service_role here) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
